# ============================================================
# VocabularyDataCleaning 环境变量配置
# 复制本文件为 .env 后修改值即可
# 所有变量前缀: VOCAB_QC_
# ============================================================

# ---------- 基础 ----------
VOCAB_QC_ENV=development

# ---------- 数据库 ----------
VOCAB_QC_DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/vocab_qc
VOCAB_QC_DB_ECHO=false

# ---------- AI API ----------
VOCAB_QC_AI_API_KEY=sk-your-api-key
VOCAB_QC_AI_API_BASE_URL=https://api.openai.com/v1
VOCAB_QC_AI_MODEL=gemini-3-flash-preview
VOCAB_QC_AI_MAX_CONCURRENCY=5
VOCAB_QC_AI_MAX_RETRIES=3
# 生产环境务必设为 false，防止 SSRF
VOCAB_QC_ALLOW_PRIVATE_AI_URL=false

# ---------- 业务 ----------
VOCAB_QC_MAX_REGENERATE_RETRIES=3
VOCAB_QC_MAX_UPLOAD_SIZE_MB=10

# ---------- JWT ----------
# 生产环境必须替换！至少 32 字节随机字符串
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
VOCAB_QC_JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-bytes
VOCAB_QC_JWT_ALGORITHM=HS256
VOCAB_QC_JWT_EXPIRE_HOURS=24

# ---------- SMTP（邮箱验证码） ----------
VOCAB_QC_SMTP_HOST=smtp.example.com
VOCAB_QC_SMTP_PORT=465
VOCAB_QC_SMTP_USER=noreply@example.com
VOCAB_QC_SMTP_PASSWORD=your-smtp-password
VOCAB_QC_SMTP_FROM_EMAIL=noreply@example.com

# ---------- 认证 ----------
# 限制注册邮箱域名（留空则不限制）
VOCAB_QC_ALLOWED_EMAIL_DOMAINS=[]
VOCAB_QC_VERIFICATION_CODE_EXPIRE_MINUTES=10

# ---------- CORS ----------
VOCAB_QC_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
