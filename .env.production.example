# ============================================================
# 生产环境配置模板
# 复制为 .env 后填写实际值
# ============================================================

# 【必填】环境标识 — 生产环境务必设为 production
VOCAB_QC_ENV=production

# 【必填】数据库连接
VOCAB_QC_DATABASE_URL_SYNC=postgresql://user:password@host:5432/vocab_qc

# 【必填】JWT 密钥 — 至少 32 字符的随机字符串
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
VOCAB_QC_JWT_SECRET_KEY=

# JWT 过期时间（小时），生产环境建议 ≤4
VOCAB_QC_JWT_EXPIRE_HOURS=4

# 【必填】SMTP 邮件配置（用于发送验证码）
VOCAB_QC_SMTP_HOST=smtp.example.com
VOCAB_QC_SMTP_PORT=465
VOCAB_QC_SMTP_USER=noreply@example.com
VOCAB_QC_SMTP_PASSWORD=
VOCAB_QC_SMTP_FROM_EMAIL=noreply@example.com

# 【必填】邮箱白名单（JSON 数组格式，限制可注册的邮箱域名）
VOCAB_QC_ALLOWED_EMAIL_DOMAINS=["example.com"]

# 【必填】CORS 允许的前端域名（JSON 数组格式，不能含 localhost）
VOCAB_QC_CORS_ORIGINS=["https://vocab.example.com"]

# 【必填】AI API 配置
VOCAB_QC_AI_API_KEY=
VOCAB_QC_AI_API_BASE_URL=https://api.example.com/v1
VOCAB_QC_AI_MODEL=gemini-3-flash-preview
VOCAB_QC_AI_MAX_CONCURRENCY=20

# 禁止私有 AI URL（防止 SSRF）
VOCAB_QC_ALLOW_PRIVATE_AI_URL=false

# 数据库 SQL 日志（生产环境务必 False）
# VOCAB_QC_DB_ECHO=false

# 重新生成最大重试次数（默认 3）
# VOCAB_QC_MAX_REGENERATE_RETRIES=3

# 验证码过期时间（分钟，默认 10）
# VOCAB_QC_VERIFICATION_CODE_EXPIRE_MINUTES=10

# 上传文件大小限制（MB，默认 10）
# VOCAB_QC_MAX_UPLOAD_SIZE_MB=10
